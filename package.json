    "test-ct:debug": "playwright test -c playwright-ct.config.ts --debug",
    "test-ct:vrt": "playwright test -c playwright-ct.vrt.config.ts",
    "test-ct:all": "playwright test -c playwright-ct.all.config.ts",
    "test-e2e": "playwright test",
    "test-e2e:ui": "playwright test --ui",
    "test-e2e:trace": "playwright test --trace on",
    "test-e2e:debug": "playwright test --debug",
    "test-e2e:vrt": "playwright test -c playwright.vrt.config.ts",
    "test-e2e:all": "playwright test -c playwright.all.config.ts"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
