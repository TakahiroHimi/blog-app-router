    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.0",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.2",
    "msw": "^2.7.5",
    "prettier": "^3.5.3",
    "rehype-pretty-code": "^0.14.1",
    "shiki": "^4.0.0",
    "tailwindcss": "^4",
